# Arsweep Environment Configuration
# Copy to .env and adjust for your environment

# Privy (Frontend)
# Get this from Privy Dashboard (App settings)
# Vite will expose env vars that start with VITE_ (or NEXT_PUBLIC_ per vite.config.ts)
# In Privy Dashboard, add your dev origin exactly (e.g. http://localhost:8080) — mismatch causes generic_connect_wallet_error.
VITE_PRIVY_APP_ID=

# Network: "devnet" | "mainnet"
# - devnet: Test environment, shows warning banner, Devnet metrics, no real funds
# - mainnet: Production, real SOL, mainnet explorer links
# Preferred (Vite):
VITE_NETWORK=devnet
# Back-compat (some builds/tools):
NEXT_PUBLIC_NETWORK=devnet

# Optional: Custom RPC endpoint (leave empty to use default for network)
# Preferred:
VITE_HELIUS_RPC_URL=
VITE_RPC_ENDPOINT=
# Back-compat:
NEXT_PUBLIC_RPC_URL=

# Optional: Syra (syraa.fun) API base (default: https://api.syraa.fun)
# NOTE: Syra production endpoints may require x402 micropayments (USDC on Solana).
# VITE_SYRA_API_BASE=https://api.syraa.fun

# Optional: Subdomain-style deployment
VITE_APP_HOST=app.arsweep.xyz
VITE_DOCS_HOST=docs.arsweep.xyz

# Treasury address (fee destination). Recommended: Squads multisig vault address.
VITE_TREASURY_ADDRESS=
